# 环境变量配置示例
# 复制此文件为 .env 并填入真实的API密钥

# Pexels API密钥
# 获取地址: https://www.pexels.com/api/
VITE_PEXELS_API=your_pexels_api_key_here

# Doubao图片生成API密钥
# 获取地址: https://console.volcengine.com/
VITE_DOUBAO_IMAGE_API_KEY=your_doubao_api_key_here

# Coze工作流PAT Token
# 获取地址: https://www.coze.cn/
VITE_PAT_TOKEN=your_coze_pat_token_here